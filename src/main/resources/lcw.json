{
  "homePage": {
    "searchBox": {
      "type": "id",
      "value": "search-form__input-field__search-input"
    },
    "cookieAcceptButton": {
      "type": "id",
      "value": "cookieseal-banner-accept"
    },
    "loginButton": {
      "type": "css",
      "value": "span.login-button"
    }
  },
  "loginPage": {
    "mailForm": {
      "type": "id",
      "value": "form-input-emailAndPhone"
    },
    "passwordForm": {
      "type": "id",
      "value": "form-input-password"
    },
    "loginButton": {
      "type": "css",
      "value": "span.lcw-button__text"
    }
  },
  "productPage": {
    "moreProductButton":{
      "type": "css",
      "value": "a.load-more__button"
    },
    "productLinks": {
      "type": "xpath",
      "value": "//a[contains(@class,'link__element') and contains(@class,'link') and not(contains(@href,'mix-match'))]"
    }
},
  "productDetailPage": {
    "colorOptions": {
      "type": "xpath",
      "value": "//a[contains(@class,'product-detail-colors__option')]"
    },
    "availableBodySizes": {
      "type": "xpath",
      "value": "//div[contains(@class,'product-options-label') and normalize-space()='Beden:']/following-sibling::div[contains(@class,'product-options-content')][1]//button[contains(@class,'option-size-box') and not(contains(@class,'option-size-box__out-of-stock'))]"
    },
    "allLengthSizes": {
      "type": "xpath",
      "value": "//div[contains(@class,'product-options-label') and normalize-space()='Boy:']/following-sibling::div[contains(@class,'product-options-content')][1]//button[contains(@class,'option-size-box')]"
    },
    "availableLengthSizes": {
      "type": "xpath",
      "value": "//div[contains(@class,'product-options-label') and normalize-space()='Boy:']/following-sibling::div[contains(@class,'product-options-content')][1]//button[contains(@class,'option-size-box') and not(contains(@class,'option-size-box__out-of-stock'))]"
    },
    "addToCartButton": {
      "type": "xpath",
      "value": "//button[.//span[normalize-space()='Sepete Ekle']]"
    },
    "gotoCartButton": {
      "type": "xpath",
      "value": "//button[.//span[normalize-space()='Sepete Git']]"
    },
    "discountedPrice": {
      "type": "css",
      "value": ".product-detail__price .price-in-cart"
    },
    "normalPrice": {
      "type": "css",
      "value": ".product-detail__price .current-price"
    }
  },
  "cartPage": {
    "cartSaleProductPrice": {
      "type": "css",
      "value": "div.shopping-cart-item__price--sale"
    },
    "cartProductPrice": {
      "type": "css",
      "value": "div.shopping-cart-item__price"
    },
    "shippingPrice": {
      "type": "xpath",
      "value": "//span[normalize-space()='Kargo Bedeli']/following-sibling::span[contains(@class,'shopping-cart-summary__amount')]"
    },
    "generalTotalPrice": {
      "type": "css",
      "value": "span.shopping-cart-summary__amount--grand-total"
    },
    "increaseQuantityButton": {
      "type": "css",
      "value": "button.shopping-cart-item__qty-btn[aria-label*='Art']"
    },
    "productQuantity": {
      "type": "css",
      "value": "span.shopping-cart-item__qty-value"

    },
    "deleteProductButton": {
      "type": "css",
      "value": "button.shopping-cart-item__icon-btn[aria-label='Sil']"
    },
    "confirmDeleteButton": {
      "type": "xpath",
      "value": "//div[contains(@class,'shopping-cart-modal')]//button[.//span[normalize-space()='Sil']]"
    },
    "emptyCartTitle": {
      "type": "xpath",
      "value": "//*[normalize-space()='Sepetin Boş']"
    }
  }


}